{
    "name": "matephp/dto",
    "description": "MatePHP - DTO - Simple Data Transfer Objects (DTO) for any framework",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Dto",
        "Mapper",
        "Data Model",
        "Data Transfer Object",
        "restful",
        "api"
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Mate\\Dto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:coverage": "pest --coverage-html build/coverage",
        "test": "pest",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "fix": "PHP_CS_FIXER_IGNORE_ENV=1 vendor/bin/php-cs-fixer fix",
        "stan": "vendor/bin/phpstan analyse src"
    }
}