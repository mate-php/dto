{
    "name": "matephp/dto",
    "description": "MatePHP - DTO - Simple Data Transfer Objects (DTO) for any framework",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Dto",
        "Mapper",
        "Data Model",
        "Data Transfer Object",
        "restful",
        "api"
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {},
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Mate\\Dto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {}
}